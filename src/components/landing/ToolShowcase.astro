---
const tools = [
  {
    title: 'Smart Text Cleaner',
    desc: 'The all-in-one text processor. Remove duplicates, trim spaces, change case, sort lines — all in real-time with instant preview.',
    href: '/smart-cleaner/',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/></svg>',
    accent: 'indigo',
    featured: true,
  },
  {
    title: 'Remove Duplicates',
    desc: 'Instantly identify and remove duplicate lines with case-sensitive or case-insensitive matching.',
    href: '/remove-duplicates/',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="2" width="13" height="13" rx="2"/><path d="M4 8H3a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2-2v-1"/></svg>',
    accent: 'violet',
  },
  {
    title: 'Remove Empty Lines',
    desc: 'Clean up blank lines instantly. Choose between fully empty lines or whitespace-only lines.',
    href: '/remove-empty-lines/',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M5 6h14M5 18h14" opacity="0.3"/></svg>',
    accent: 'fuchsia',
  },
  {
    title: 'Sort Lines',
    desc: 'Sort text lines alphabetically with ascending, descending, natural, and case-insensitive options.',
    href: '/sort-lines/',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5h10M11 9h7M11 13h4M3 17l3 3 3-3M6 18V4"/></svg>',
    accent: 'cyan',
  },
  {
    title: 'Word Counter',
    desc: 'Detailed text analytics — words, characters, sentences, paragraphs, reading time, and speaking time.',
    href: '/word-counter/',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 9h16M4 15h16M10 3L8 21M16 3l-2 18"/></svg>',
    accent: 'indigo',
  },
  {
    title: 'Case Converter',
    desc: 'Convert text between UPPERCASE, lowercase, Title Case, Sentence case, and tOGGLE cASE instantly.',
    href: '/case-converter/',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/></svg>',
    accent: 'violet',
  },
];
---

<section class="section tool-showcase" id="tools">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow mono">TOOLS</span>
      <h2 class="display-lg">Everything You Need,<br /><span class="text-gradient">One Platform</span></h2>
      <p class="body-lg text-secondary">
        Powerful text utilities designed for speed and simplicity.
      </p>
    </div>

    <div class="tools-grid stagger-children">
      {tools.map(tool => (
        <a href={tool.href} class:list={['tool-card glass-card-solid', { featured: tool.featured }]}>
          <div class:list={['tool-icon', tool.accent]}>
            <Fragment set:html={tool.icon} />
          </div>
          <h3 class="tool-card-title">{tool.title}</h3>
          <p class="tool-card-desc">{tool.desc}</p>
          <span class="tool-card-link">
            Try it
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
          {tool.featured && <span class="featured-badge">Flagship</span>}
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .section-header {
    text-align: center;
    margin-bottom: var(--sp-12);
  }

  .section-eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--accent-indigo);
    margin-bottom: var(--sp-4);
  }

  .section-header h2 {
    margin-bottom: var(--sp-4);
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-6);
  }

  @media (max-width: 1024px) {
    .tools-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .tools-grid { grid-template-columns: 1fr; }
  }

  .tool-card {
    display: flex;
    flex-direction: column;
    padding: var(--sp-6);
    text-decoration: none;
    position: relative;
    overflow: hidden;
    transition: transform var(--transition-base), border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .tool-card:hover {
    transform: translateY(-4px);
    border-color: var(--border-strong);
    box-shadow: var(--shadow-lg), var(--shadow-glow-accent);
  }

  .tool-card.featured {
    border-color: rgba(99,102,241,0.25);
    background: linear-gradient(135deg, var(--surface-2), rgba(99,102,241,0.06));
  }

  .featured-badge {
    position: absolute;
    top: var(--sp-4);
    right: var(--sp-4);
    font-size: 0.6875rem;
    font-weight: 600;
    padding: 2px 10px;
    border-radius: var(--radius-full);
    background: var(--gradient-accent);
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .tool-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-lg);
    margin-bottom: var(--sp-4);
  }

  .tool-icon svg {
    width: 22px;
    height: 22px;
  }

  .tool-icon.indigo { background: rgba(99,102,241,0.12); color: var(--accent-indigo); }
  .tool-icon.violet { background: rgba(139,92,246,0.12); color: var(--accent-violet); }
  .tool-icon.fuchsia { background: rgba(217,70,239,0.12); color: var(--accent-fuchsia); }
  .tool-icon.cyan { background: rgba(34,211,238,0.12); color: var(--accent-cyan); }

  .tool-card-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--sp-2);
    letter-spacing: -0.01em;
  }

  .tool-card-desc {
    font-size: 0.875rem;
    color: var(--text-tertiary);
    line-height: 1.6;
    margin-bottom: var(--sp-5);
    flex-grow: 1;
  }

  .tool-card-link {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-1);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--accent-indigo);
    transition: gap var(--transition-fast);
  }

  .tool-card:hover .tool-card-link {
    gap: var(--sp-2);
  }
</style>
