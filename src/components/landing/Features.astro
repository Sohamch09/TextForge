---
const features = [
  {
    title: 'Real-Time Processing',
    desc: 'Every change updates instantly. No submit buttons, no page reloads — just type and see results immediately.',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>',
  },
  {
    title: 'Zero Friction Workflow',
    desc: 'No sign-ups, no ads, no pop-ups. Open a tool, paste your text, and get results. That simple.',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M12 6v6l4 2"/></svg>',
  },
  {
    title: 'Mobile-First Design',
    desc: 'Every tool works beautifully on phones, tablets, and desktops. Process text from anywhere.',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><path d="M12 18h.01"/></svg>',
  },
  {
    title: 'Keyboard Shortcuts',
    desc: 'Power user? Use Ctrl+Shift+C to copy, Ctrl+Shift+D to download. No mouse required.',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2" ry="2"/><path d="M6 8h.001M10 8h.001M14 8h.001M18 8h.001M8 12h.001M12 12h.001M16 12h.001M6 16h12"/></svg>',
  },
];
---

<section class="section features" id="features">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow mono">FEATURES</span>
      <h2 class="display-lg">Built for <span class="text-gradient">Speed & Simplicity</span></h2>
      <p class="body-lg text-secondary">
        Every feature is designed to save you time and eliminate friction.
      </p>
    </div>

    <div class="features-grid stagger-children">
      {features.map(feature => (
        <div class="feature-card">
          <div class="feature-icon">
            <Fragment set:html={feature.icon} />
          </div>
          <h3 class="feature-title">{feature.title}</h3>
          <p class="feature-desc">{feature.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    background: var(--surface-1);
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--sp-12);
  }

  .section-eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--accent-indigo);
    margin-bottom: var(--sp-4);
  }

  .section-header h2 {
    margin-bottom: var(--sp-4);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-6);
  }

  @media (max-width: 1024px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .features-grid { grid-template-columns: 1fr; }
  }

  .feature-card {
    padding: var(--sp-6);
    border-radius: var(--radius-xl);
    background: var(--surface-2);
    border: 1px solid var(--border-subtle);
    transition: border-color var(--transition-base), transform var(--transition-base);
  }

  .feature-card:hover {
    border-color: var(--border-default);
    transform: translateY(-2px);
  }

  .feature-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-lg);
    background: rgba(99,102,241,0.10);
    color: var(--accent-indigo);
    margin-bottom: var(--sp-4);
  }

  .feature-icon svg {
    width: 22px;
    height: 22px;
  }

  .feature-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--sp-2);
  }

  .feature-desc {
    font-size: 0.875rem;
    color: var(--text-tertiary);
    line-height: 1.6;
  }
</style>
