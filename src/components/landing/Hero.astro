---
---
<section class="hero" id="hero">
  <!-- Animated mesh background -->
  <div class="hero-mesh" aria-hidden="true">
    <div class="mesh-orb mesh-orb-1"></div>
    <div class="mesh-orb mesh-orb-2"></div>
    <div class="mesh-orb mesh-orb-3"></div>
  </div>

  <div class="container hero-container">
    <div class="hero-badge animate-fade-in">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
      <span>Instant Processing · Zero Friction · 100% Private</span>
    </div>

    <h1 class="display-xl hero-title animate-slide-up">
      Clean, Transform &<br />Analyze Text <span class="text-gradient">Instantly</span>
    </h1>

    <p class="body-lg hero-subtitle animate-slide-up" style="animation-delay:100ms">
      The free word counter, AI text cleaner, case converter, and duplicate remover<br class="hide-mobile" />
      for developers, students, writers, and professionals. No sign-up, no ads — just results.
    </p>

    <div class="hero-cta animate-slide-up" style="animation-delay:200ms">
      <a href="/smart-cleaner/" class="btn btn-primary btn-lg">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/><path d="M20 3v4M22 5h-4"/></svg>
        Start Cleaning Text
      </a>
      <a href="#tools" class="btn btn-secondary btn-lg">
        Explore All Tools
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

    <!-- Stats Strip -->
    <div class="hero-stats animate-slide-up" style="animation-delay:350ms">
      <div class="hero-stat">
        <span class="hero-stat-value">6+</span>
        <span class="hero-stat-label">Powerful Tools</span>
      </div>
      <div class="hero-stat-divider"></div>
      <div class="hero-stat">
        <span class="hero-stat-value">0ms</span>
        <span class="hero-stat-label">Processing Delay</span>
      </div>
      <div class="hero-stat-divider"></div>
      <div class="hero-stat">
        <span class="hero-stat-value">100%</span>
        <span class="hero-stat-label">Client-Side</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: var(--sp-24) 0 var(--sp-20);
    min-height: 85vh;
    display: flex;
    align-items: center;
  }

  @media (max-width: 768px) {
    .hero {
      padding: var(--sp-16) 0 var(--sp-12);
      min-height: auto;
    }
  }

  /* Mesh Background */
  .hero-mesh {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .mesh-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.5;
    animation: float 8s ease-in-out infinite;
  }

  .mesh-orb-1 {
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(99,102,241,0.25), transparent 70%);
    top: -200px;
    left: -100px;
    animation-delay: 0s;
  }

  .mesh-orb-2 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(139,92,246,0.20), transparent 70%);
    top: -50px;
    right: -150px;
    animation-delay: -3s;
  }

  .mesh-orb-3 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(217,70,239,0.15), transparent 70%);
    bottom: -100px;
    left: 30%;
    animation-delay: -5s;
  }

  .hero-container {
    position: relative;
    z-index: 1;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-1) var(--sp-4);
    border-radius: var(--radius-full);
    background: rgba(99,102,241,0.10);
    border: 1px solid rgba(99,102,241,0.20);
    color: var(--accent-indigo);
    font-size: 0.8125rem;
    font-weight: 500;
    margin-bottom: var(--sp-8);
  }

  .hero-title {
    max-width: 800px;
    margin-bottom: var(--sp-6);
  }

  .hero-subtitle {
    color: var(--text-secondary);
    max-width: 600px;
    margin-bottom: var(--sp-10);
  }

  .hide-mobile {
    display: inline;
  }

  @media (max-width: 640px) {
    .hide-mobile { display: none; }
  }

  .hero-cta {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: var(--sp-12);
  }

  @media (max-width: 480px) {
    .hero-cta {
      flex-direction: column;
      width: 100%;
    }
    .hero-cta .btn {
      width: 100%;
    }
  }

  .btn-lg {
    padding: var(--sp-4) var(--sp-8);
    font-size: 1rem;
  }

  /* Stats Strip */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: var(--sp-8);
    padding: var(--sp-5) var(--sp-8);
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    backdrop-filter: blur(12px);
  }

  @media (max-width: 640px) {
    .hero-stats {
      flex-direction: column;
      gap: var(--sp-4);
      padding: var(--sp-5) var(--sp-6);
    }

    .hero-stat-divider {
      width: 60px !important;
      height: 1px !important;
    }
  }

  .hero-stat {
    text-align: center;
  }

  .hero-stat-value {
    display: block;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  .hero-stat-label {
    font-size: 0.75rem;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 500;
  }

  .hero-stat-divider {
    width: 1px;
    height: 32px;
    background: var(--border-subtle);
  }
</style>
