---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact — TextForge"
  description="Get in touch with the TextForge team. We'd love to hear your feedback, suggestions, or questions."
>
  <div class="container legal-page">
    <div class="tool-header">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span class="sep">/</span>
        <span>Contact</span>
      </div>
      <h1><span class="text-gradient">Get in</span> Touch</h1>
      <p class="tool-desc">Have feedback, a feature request, or just want to say hello? We'd love to hear from you.</p>
    </div>

    <div class="contact-grid">
      <!-- Contact Cards -->
      <div class="contact-cards">
        <!-- LinkedIn -->
        <a href="https://www.linkedin.com/in/soham-choudhury-a329a524a" target="_blank" rel="noopener noreferrer" class="contact-card">
          <div class="contact-icon linkedin">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </div>
          <div class="contact-info">
            <h3>LinkedIn</h3>
            <p>Connect with us on LinkedIn</p>
          </div>
          <svg class="contact-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>

        <!-- GitHub -->
        <a href="https://github.com/Sohamch09/TextForge" class="contact-card">
          <div class="contact-icon github">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
          </div>
          <div class="contact-info">
            <h3>GitHub</h3>
            <p>Report issues or contribute</p>
          </div>
          <svg class="contact-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>

        <!-- Email -->
        <a href="mailto:choudhurysoham09@gmail.com" class="contact-card">
          <div class="contact-icon email">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </div>
          <div class="contact-info">
            <h3>Email</h3>
            <p>choudhurysoham09@gmail.com</p>
          </div>
          <svg class="contact-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <!-- Info Panel -->
      <div class="contact-info-panel">
        <div class="info-card glass-card-solid" style="padding: var(--sp-8);">
          <h2>Frequently Asked</h2>
          <div class="info-items">
            <div class="info-item">
              <h4>🐛 Found a bug?</h4>
              <p>Open an issue on GitHub with steps to reproduce the problem. Include which tool you were using and the text that caused the issue (if not sensitive).</p>
            </div>
            <div class="info-item">
              <h4>💡 Feature request?</h4>
              <p>We love hearing ideas! Open a GitHub issue with the "feature request" label, or message us on LinkedIn describing what you'd like to see.</p>
            </div>
            <div class="info-item">
              <h4>🔒 Privacy concern?</h4>
              <p>All processing happens in your browser. We never see your text. Read our <a href="/privacy-policy/">Privacy Policy</a> for full details.</p>
            </div>
            <div class="info-item">
              <h4>⏱️ Response time</h4>
              <p>We typically respond within 24–48 hours on weekdays. For urgent issues, LinkedIn is the fastest channel.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .legal-page {
    padding-top: var(--sp-8);
    padding-bottom: var(--sp-16);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-8);
    align-items: start;
  }

  @media (max-width: 1024px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Contact Cards */
  .contact-cards {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }

  .contact-card {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    padding: var(--sp-5) var(--sp-6);
    background: var(--surface-1);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .contact-card:hover {
    border-color: var(--border-strong);
    background: var(--surface-2);
    transform: translateX(4px);
  }

  .contact-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-lg);
    flex-shrink: 0;
  }

  .contact-icon.linkedin {
    background: rgba(10, 102, 194, 0.12);
    color: #0a66c2;
  }

  .contact-icon.github {
    background: rgba(255, 255, 255, 0.08);
    color: var(--text-primary);
  }

  .contact-icon.email {
    background: rgba(99, 102, 241, 0.12);
    color: var(--accent-indigo);
  }

  .contact-info {
    flex: 1;
  }

  .contact-info h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 2px;
  }

  .contact-info p {
    font-size: 0.8125rem;
    color: var(--text-tertiary);
  }

  .contact-arrow {
    color: var(--text-muted);
    flex-shrink: 0;
    transition: transform var(--transition-fast), color var(--transition-fast);
  }

  .contact-card:hover .contact-arrow {
    color: var(--accent-indigo);
    transform: translateX(4px);
  }

  /* Info Panel */
  .info-card h2 {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--sp-6);
    letter-spacing: -0.01em;
  }

  .info-items {
    display: flex;
    flex-direction: column;
    gap: var(--sp-6);
  }

  .info-item h4 {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--sp-1);
  }

  .info-item p {
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    line-height: 1.7;
  }

  .info-item a {
    color: var(--accent-indigo);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .info-item a:hover {
    color: var(--accent-violet);
  }
</style>
