---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Remove Duplicate Lines — TextForge"
  description="Instantly remove duplicate lines from your text. Case-sensitive and case-insensitive matching with real-time statistics."
>
  <div class="container tool-page">
    <div class="tool-header">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span class="sep">/</span>
        <span>Remove Duplicate Lines</span>
      </div>
      <h1>Remove <span class="text-gradient">Duplicate</span> Lines</h1>
      <p class="tool-desc">Instantly identify and remove duplicate lines with case-sensitive or case-insensitive matching.</p>
    </div>

    <!-- Options -->
    <div class="options-panel" id="dup-options">
      <h3>Options</h3>
      <div class="options-grid">
        <label class="toggle">
          <input type="checkbox" id="dup-case-sensitive" checked />
          <span class="toggle-track"></span>
          <span class="toggle-label">Case-Sensitive Matching</span>
        </label>
      </div>
    </div>

    <!-- Panels -->
    <div class="split-panels">
      <div class="panel glass-card-sm">
        <div class="panel-header">
          <span class="panel-title">Input</span>
          <button class="btn-icon" id="dup-clear" data-tooltip="Clear" aria-label="Clear input">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
          </button>
        </div>
        <textarea class="textarea" id="dup-input" placeholder="Paste text with duplicate lines..." spellcheck="false" aria-label="Input text" style="border:none;border-radius:0;min-height:320px;"></textarea>
        <div class="count-bar">
          <span><strong id="dup-in-lines">0</strong> lines</span>
          <span><strong id="dup-in-chars">0</strong> chars</span>
        </div>
      </div>
      <div class="panel glass-card-sm">
        <div class="panel-header">
          <span class="panel-title">Output</span>
          <div class="action-bar">
            <button class="btn-icon" id="dup-copy" data-tooltip="Copy" aria-label="Copy output">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            </button>
            <button class="btn-icon" id="dup-download" data-tooltip="Download" aria-label="Download">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
            </button>
          </div>
        </div>
        <textarea class="textarea textarea-readonly" id="dup-output" readonly placeholder="Unique lines will appear here..." aria-label="Output text" style="border:none;border-radius:0;min-height:320px;"></textarea>
        <div class="count-bar">
          <span><strong id="dup-out-lines">0</strong> lines</span>
          <span><strong id="dup-out-chars">0</strong> chars</span>
        </div>
      </div>
    </div>

    <!-- Stats -->
    <div class="stats-section" style="margin-top:var(--sp-8)">
      <h3 class="stats-title">Statistics</h3>
      <div class="stats-grid">
        <div class="stat-card"><div class="stat-icon indigo"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg></div><div class="stat-label">Total Lines</div><div class="stat-value" id="dup-stat-total">0</div></div>
        <div class="stat-card"><div class="stat-icon success"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div><div class="stat-label">Unique Lines</div><div class="stat-value" id="dup-stat-unique">0</div></div>
        <div class="stat-card"><div class="stat-icon error"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="8" y="2" width="13" height="13" rx="2"/><path d="M4 8H3a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2-2v-1"/></svg></div><div class="stat-label">Duplicates Found</div><div class="stat-value" id="dup-stat-dups">0</div></div>
        <div class="stat-card"><div class="stat-icon violet"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg></div><div class="stat-label">Reduction</div><div class="stat-value" id="dup-stat-reduction">0%</div></div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .tool-page { padding-top: var(--sp-8); padding-bottom: var(--sp-16); }
  .options-panel { margin-bottom: var(--sp-6); }
  .panel { overflow: hidden; display: flex; flex-direction: column; }
  .stats-title { font-size: 0.8125rem; font-weight: 600; color: var(--text-tertiary); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: var(--sp-4); }
</style>

<script>
  import { removeDuplicateLines, countLines, countCharacters, copyToClipboard, downloadAsText, formatNumber, percentReduction } from '../scripts/text-utils.js';

  const input = document.getElementById('dup-input');
  const output = document.getElementById('dup-output');
  const caseSensitive = document.getElementById('dup-case-sensitive');

  function process() {
    const text = input.value;
    const { result, duplicatesRemoved } = removeDuplicateLines(text, caseSensitive.checked);
    output.value = result;

    const il = countLines(text);
    const ol = countLines(result);
    document.getElementById('dup-in-lines').textContent = formatNumber(il);
    document.getElementById('dup-in-chars').textContent = formatNumber(countCharacters(text));
    document.getElementById('dup-out-lines').textContent = formatNumber(ol);
    document.getElementById('dup-out-chars').textContent = formatNumber(countCharacters(result));
    document.getElementById('dup-stat-total').textContent = formatNumber(il);
    document.getElementById('dup-stat-unique').textContent = formatNumber(ol);
    document.getElementById('dup-stat-dups').textContent = formatNumber(duplicatesRemoved);
    document.getElementById('dup-stat-reduction').textContent = percentReduction(il, ol);
  }

  input.addEventListener('input', process);
  caseSensitive.addEventListener('change', process);

  document.getElementById('dup-clear')?.addEventListener('click', () => { input.value = ''; process(); window.showToast?.('Cleared', 'info'); });
  document.getElementById('dup-copy')?.addEventListener('click', async () => { const ok = await copyToClipboard(output.value); window.showToast?.(ok ? 'Copied!' : 'Failed', ok ? 'success' : 'error'); });
  document.getElementById('dup-download')?.addEventListener('click', () => { downloadAsText(output.value, 'duplicates-removed.txt'); window.showToast?.('Downloaded', 'success'); });
</script>
