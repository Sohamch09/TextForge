---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/landing/Hero.astro';
import ToolShowcase from '../components/landing/ToolShowcase.astro';
import Features from '../components/landing/Features.astro';
import Benefits from '../components/landing/Benefits.astro';
import Comparison from '../components/landing/Comparison.astro';
import Testimonials from '../components/landing/Testimonials.astro';
import FAQ from '../components/landing/FAQ.astro';
import SEOContent from '../components/landing/SEOContent.astro';
---

<Layout
  title="Word Counter & Free AI Text Cleaner — TextForge | All-in-One Text Utility Online"
  description="TextForge is a free word counter and AI text cleaner online. Count words, remove duplicate lines from text, convert uppercase to lowercase, generate title case, and clean text instantly — all in one text utility online. 100% free, private, and ad-free."
  keywords="word counter, word counter free, word counter online, ai text cleaner, ai text cleaner free, all in one text utility online, deduplicate text list online, remove duplicate lines from text, convert uppercase to lowercase, title case generator, change text case instantly"
>
  <Hero />
  <ToolShowcase />
  <Features />
  <Benefits />
  <Comparison />
  <Testimonials />
  <FAQ />
  <SEOContent />

  <!-- CTA band before footer -->
  <section class="cta-band">
    <div class="container cta-band-inner">
      <div class="cta-mesh" aria-hidden="true">
        <div class="cta-orb cta-orb-1"></div>
        <div class="cta-orb cta-orb-2"></div>
      </div>
      <h2 class="display-md">Ready to transform your text?</h2>
      <p class="body-lg text-secondary">Start using TextForge now — no sign-up required.</p>
      <a href="/smart-cleaner/" class="btn btn-primary btn-lg" style="margin-top:var(--sp-6);">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/></svg>
        Start Cleaning Text
      </a>
    </div>
  </section>
</Layout>

<style>
  .cta-band {
    position: relative;
    overflow: hidden;
    padding: var(--sp-24) 0;
    text-align: center;
  }

  .cta-band-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cta-band-inner h2 {
    margin-bottom: var(--sp-3);
  }

  .cta-mesh {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .cta-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.4;
  }

  .cta-orb-1 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(99,102,241,0.20), transparent 70%);
    top: -100px;
    right: -50px;
  }

  .cta-orb-2 {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(217,70,239,0.15), transparent 70%);
    bottom: -80px;
    left: -30px;
  }

  .btn-lg {
    padding: var(--sp-4) var(--sp-8);
    font-size: 1rem;
  }
</style>
