---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="AI Text Cleaner Free — All-in-One Text Utility Online | TextForge"
  description="The ultimate AI text cleaner free online. Remove duplicates, trim spaces, change text case, sort lines, and clean text — all in one text utility online with real-time preview. No sign-up, 100% private."
  keywords="ai text cleaner, ai text cleaner free, all in one text utility online, text cleaner online, clean text online, smart text cleaner, text processing tool"
>
  <div class="container tool-page">
    <!-- Page Header -->
    <div class="tool-header">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span class="sep">/</span>
        <span>Smart Text Cleaner</span>
      </div>
      <h1><span class="text-gradient">Smart</span> Text Cleaner</h1>
      <p class="tool-desc">
        The all-in-one text processor. Combine multiple transformations and see results instantly.
        <span class="kbd-hint">
          <span class="kbd">Ctrl</span>+<span class="kbd">Shift</span>+<span class="kbd">C</span> Copy
          <span class="kbd">Ctrl</span>+<span class="kbd">Shift</span>+<span class="kbd">D</span> Download
        </span>
      </p>
    </div>

    <!-- Processing Options -->
    <div class="options-panel" id="options-panel">
      <h3>Processing Options</h3>
      <div class="options-grid">
        <label class="toggle" id="opt-remove-duplicates">
          <input type="checkbox" data-option="removeDuplicates" />
          <span class="toggle-track"></span>
          <span class="toggle-label">Remove Duplicate Lines</span>
        </label>
        <label class="toggle" id="opt-remove-empty">
          <input type="checkbox" data-option="removeEmpty" />
          <span class="toggle-track"></span>
          <span class="toggle-label">Remove Empty Lines</span>
        </label>
        <label class="toggle" id="opt-trim">
          <input type="checkbox" data-option="trimSpaces" />
          <span class="toggle-track"></span>
          <span class="toggle-label">Trim Leading/Trailing Spaces</span>
        </label>
        <label class="toggle" id="opt-uppercase">
          <input type="checkbox" data-option="toUppercase" />
          <span class="toggle-track"></span>
          <span class="toggle-label">Convert to UPPERCASE</span>
        </label>
        <label class="toggle" id="opt-lowercase">
          <input type="checkbox" data-option="toLowercase" />
          <span class="toggle-track"></span>
          <span class="toggle-label">Convert to lowercase</span>
        </label>
        <label class="toggle" id="opt-titlecase">
          <input type="checkbox" data-option="toTitleCase" />
          <span class="toggle-track"></span>
          <span class="toggle-label">Convert to Title Case</span>
        </label>
        <label class="toggle" id="opt-sort-az">
          <input type="checkbox" data-option="sortAZ" />
          <span class="toggle-track"></span>
          <span class="toggle-label">Sort Lines A → Z</span>
        </label>
        <label class="toggle" id="opt-sort-za">
          <input type="checkbox" data-option="sortZA" />
          <span class="toggle-track"></span>
          <span class="toggle-label">Sort Lines Z → A</span>
        </label>
        <label class="toggle" id="opt-reverse">
          <input type="checkbox" data-option="reverseLines" />
          <span class="toggle-track"></span>
          <span class="toggle-label">Reverse Line Order</span>
        </label>
      </div>
    </div>

    <!-- Split Panels -->
    <div class="split-panels">
      <!-- Input Panel -->
      <div class="panel glass-card-sm" id="input-panel">
        <div class="panel-header">
          <span class="panel-title">Input</span>
          <div class="action-bar">
            <button class="btn-icon" id="btn-clear-input" data-tooltip="Clear input" aria-label="Clear input">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
            </button>
          </div>
        </div>
        <div class="drop-zone" id="drop-zone">
          <div class="drop-zone-overlay">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
            &nbsp;Drop your text file here
          </div>
          <textarea
            class="textarea"
            id="input-text"
            placeholder="Paste your text here, or drag and drop a .txt file..."
            spellcheck="false"
            aria-label="Input text"
          ></textarea>
        </div>
        <div class="count-bar" id="input-counts">
          <span><strong id="input-chars">0</strong> chars</span>
          <span><strong id="input-words">0</strong> words</span>
          <span><strong id="input-lines">0</strong> lines</span>
        </div>
      </div>

      <!-- Output Panel -->
      <div class="panel glass-card-sm" id="output-panel">
        <div class="panel-header">
          <span class="panel-title">Output</span>
          <div class="action-bar">
            <button class="btn-icon" id="btn-copy" data-tooltip="Copy output" aria-label="Copy output">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            </button>
            <button class="btn-icon" id="btn-download" data-tooltip="Download .txt" aria-label="Download as text file">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
            </button>
            <button class="btn-icon" id="btn-share" data-tooltip="Copy page link" aria-label="Share">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
            </button>
            <div class="separator"></div>
            <button class="btn-icon" id="btn-fullscreen" data-tooltip="Fullscreen" aria-label="Toggle fullscreen">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>
            </button>
          </div>
        </div>
        <textarea
          class="textarea textarea-readonly"
          id="output-text"
          readonly
          placeholder="Processed text will appear here..."
          aria-label="Output text"
        ></textarea>
        <div class="count-bar" id="output-counts">
          <span><strong id="output-chars">0</strong> chars</span>
          <span><strong id="output-words">0</strong> words</span>
          <span><strong id="output-lines">0</strong> lines</span>
        </div>
      </div>
    </div>

    <!-- Statistics Panel -->
    <div class="stats-section">
      <h3 class="stats-title">Processing Statistics</h3>
      <div class="stats-grid" id="stats-grid">
        <div class="stat-card">
          <div class="stat-icon indigo">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
          </div>
          <div class="stat-label">Input Lines</div>
          <div class="stat-value" id="stat-input-lines">0</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon violet">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
          </div>
          <div class="stat-label">Output Lines</div>
          <div class="stat-value" id="stat-output-lines">0</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon fuchsia">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="8" y="2" width="13" height="13" rx="2"/><path d="M4 8H3a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2-2v-1"/></svg>
          </div>
          <div class="stat-label">Duplicates Removed</div>
          <div class="stat-value" id="stat-duplicates">0</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon cyan">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/></svg>
          </div>
          <div class="stat-label">Empty Lines Removed</div>
          <div class="stat-value" id="stat-empty">0</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon indigo">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="4 7 4 4 20 4 20 7"/><line x1="12" y1="4" x2="12" y2="20"/></svg>
          </div>
          <div class="stat-label">Chars Before</div>
          <div class="stat-value" id="stat-chars-before">0</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon violet">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="4 7 4 4 20 4 20 7"/><line x1="12" y1="4" x2="12" y2="20"/></svg>
          </div>
          <div class="stat-label">Chars After</div>
          <div class="stat-value" id="stat-chars-after">0</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon success">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
          </div>
          <div class="stat-label">Reduction</div>
          <div class="stat-value" id="stat-reduction">0%</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon warning">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 9h16M4 15h16M10 3L8 21M16 3l-2 18"/></svg>
          </div>
          <div class="stat-label">Words Before → After</div>
          <div class="stat-value" id="stat-words">0 → 0</div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .tool-page {
    padding-top: var(--sp-8);
    padding-bottom: var(--sp-16);
  }

  .kbd-hint {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    margin-left: var(--sp-4);
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .kbd-hint { display: none; }
  }

  .options-panel {
    margin-bottom: var(--sp-6);
  }

  .panel {
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .panel .textarea {
    border: none;
    border-radius: 0;
    flex: 1;
    min-height: 320px;
  }

  .panel .textarea:focus {
    box-shadow: none;
  }

  .stats-section {
    margin-top: var(--sp-8);
  }

  .stats-title {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--sp-4);
  }
</style>

<script>
  import {
    removeDuplicateLines,
    removeEmptyLines,
    trimLines,
    toUpperCase,
    toLowerCase,
    toTitleCase,
    sortLines,
    reverseLines,
    countWords,
    countCharacters,
    countLines,
    copyToClipboard,
    downloadAsText,
    readTextFile,
    formatNumber,
    percentReduction,
  } from '../scripts/text-utils.js';

  // DOM elements
  const inputEl = document.getElementById('input-text');
  const outputEl = document.getElementById('output-text');
  const optionsPanel = document.getElementById('options-panel');

  // Count elements
  const inputChars = document.getElementById('input-chars');
  const inputWords = document.getElementById('input-words');
  const inputLines = document.getElementById('input-lines');
  const outputChars = document.getElementById('output-chars');
  const outputWords = document.getElementById('output-words');
  const outputLines = document.getElementById('output-lines');

  // Stat elements
  const statInputLines = document.getElementById('stat-input-lines');
  const statOutputLines = document.getElementById('stat-output-lines');
  const statDuplicates = document.getElementById('stat-duplicates');
  const statEmpty = document.getElementById('stat-empty');
  const statCharsBefore = document.getElementById('stat-chars-before');
  const statCharsAfter = document.getElementById('stat-chars-after');
  const statReduction = document.getElementById('stat-reduction');
  const statWords = document.getElementById('stat-words');

  // Process text based on active options
  function processText() {
    let text = inputEl.value;
    const originalText = text;

    // Get active options
    const opts = {};
    optionsPanel.querySelectorAll('input[data-option]').forEach(input => {
      opts[input.dataset.option] = input.checked;
    });

    // Track stats
    let duplicatesRemoved = 0;
    let emptyLinesRemoved = 0;

    // Apply transformations in order
    if (opts.removeDuplicates) {
      const result = removeDuplicateLines(text, true);
      text = result.result;
      duplicatesRemoved = result.duplicatesRemoved;
    }

    if (opts.removeEmpty) {
      const result = removeEmptyLines(text, true);
      text = result.result;
      emptyLinesRemoved = result.emptyLinesRemoved;
    }

    if (opts.trimSpaces) {
      text = trimLines(text);
    }

    // Case conversions (mutually exclusive — last one wins)
    if (opts.toUppercase) text = toUpperCase(text);
    if (opts.toLowercase) text = toLowerCase(text);
    if (opts.toTitleCase) text = toTitleCase(text);

    // Sorting (mutually exclusive — last one wins)
    if (opts.sortAZ) text = sortLines(text, 'asc', false, false);
    if (opts.sortZA) text = sortLines(text, 'desc', false, false);

    if (opts.reverseLines) text = reverseLines(text);

    // Update output
    outputEl.value = text;

    // Update counts
    const ic = countCharacters(originalText);
    const iw = countWords(originalText);
    const il = countLines(originalText);
    const oc = countCharacters(text);
    const ow = countWords(text);
    const ol = countLines(text);

    inputChars.textContent = formatNumber(ic);
    inputWords.textContent = formatNumber(iw);
    inputLines.textContent = formatNumber(il);
    outputChars.textContent = formatNumber(oc);
    outputWords.textContent = formatNumber(ow);
    outputLines.textContent = formatNumber(ol);

    // Update stats
    statInputLines.textContent = formatNumber(il);
    statOutputLines.textContent = formatNumber(ol);
    statDuplicates.textContent = formatNumber(duplicatesRemoved);
    statEmpty.textContent = formatNumber(emptyLinesRemoved);
    statCharsBefore.textContent = formatNumber(ic);
    statCharsAfter.textContent = formatNumber(oc);
    statReduction.textContent = percentReduction(ic, oc);
    statWords.textContent = `${formatNumber(iw)} → ${formatNumber(ow)}`;

    // Auto-save to session
    try { sessionStorage.setItem('tf-smart-input', originalText); } catch {}
  }

  // Bind events
  inputEl.addEventListener('input', processText);
  optionsPanel.querySelectorAll('input[data-option]').forEach(input => {
    input.addEventListener('change', () => {
      // Mutual exclusivity for case options
      if (['toUppercase', 'toLowercase', 'toTitleCase'].includes(input.dataset.option) && input.checked) {
        ['toUppercase', 'toLowercase', 'toTitleCase'].forEach(opt => {
          if (opt !== input.dataset.option) {
            const other = optionsPanel.querySelector(`input[data-option="${opt}"]`);
            if (other) other.checked = false;
          }
        });
      }
      // Mutual exclusivity for sort options
      if (['sortAZ', 'sortZA'].includes(input.dataset.option) && input.checked) {
        ['sortAZ', 'sortZA'].forEach(opt => {
          if (opt !== input.dataset.option) {
            const other = optionsPanel.querySelector(`input[data-option="${opt}"]`);
            if (other) other.checked = false;
          }
        });
      }
      processText();
    });
  });

  // Restore session
  try {
    const saved = sessionStorage.getItem('tf-smart-input');
    if (saved) { inputEl.value = saved; processText(); }
  } catch {}

  // Clear input
  document.getElementById('btn-clear-input')?.addEventListener('click', () => {
    inputEl.value = '';
    processText();
    try { sessionStorage.removeItem('tf-smart-input'); } catch {}
    window.showToast?.('Input cleared', 'info');
  });

  // Copy output
  document.getElementById('btn-copy')?.addEventListener('click', async () => {
    const ok = await copyToClipboard(outputEl.value);
    window.showToast?.(ok ? 'Copied to clipboard!' : 'Failed to copy', ok ? 'success' : 'error');
  });

  // Download
  document.getElementById('btn-download')?.addEventListener('click', () => {
    downloadAsText(outputEl.value, 'textforge-cleaned.txt');
    window.showToast?.('File downloaded', 'success');
  });

  // Share
  document.getElementById('btn-share')?.addEventListener('click', async () => {
    const ok = await copyToClipboard(window.location.href);
    window.showToast?.(ok ? 'Link copied to clipboard!' : 'Failed to copy link', ok ? 'success' : 'error');
  });

  // Fullscreen
  document.getElementById('btn-fullscreen')?.addEventListener('click', () => {
    const panel = document.getElementById('output-panel');
    panel?.classList.toggle('fullscreen-active');
    const isFs = panel?.classList.contains('fullscreen-active');
    window.showToast?.(isFs ? 'Press Escape or click again to exit' : 'Exited fullscreen', 'info');
  });

  // Keyboard shortcuts
  document.addEventListener('keydown', (e) => {
    if (e.ctrlKey && e.shiftKey) {
      if (e.key === 'C' || e.key === 'c') {
        e.preventDefault();
        document.getElementById('btn-copy')?.click();
      } else if (e.key === 'D' || e.key === 'd') {
        e.preventDefault();
        document.getElementById('btn-download')?.click();
      } else if (e.key === 'X' || e.key === 'x') {
        e.preventDefault();
        document.getElementById('btn-clear-input')?.click();
      }
    }
    if (e.key === 'Escape') {
      const panel = document.getElementById('output-panel');
      if (panel?.classList.contains('fullscreen-active')) {
        panel.classList.remove('fullscreen-active');
      }
    }
  });

  // Drag & Drop
  const dropZone = document.getElementById('drop-zone');
  if (dropZone) {
    ['dragenter', 'dragover'].forEach(evt => {
      dropZone.addEventListener(evt, (e) => {
        e.preventDefault();
        dropZone.classList.add('drag-over');
      });
    });
    ['dragleave', 'drop'].forEach(evt => {
      dropZone.addEventListener(evt, () => {
        dropZone.classList.remove('drag-over');
      });
    });
    dropZone.addEventListener('drop', async (e) => {
      e.preventDefault();
      const file = e.dataTransfer?.files?.[0];
      if (file && file.type === 'text/plain') {
        try {
          const text = await readTextFile(file);
          inputEl.value = text;
          processText();
          window.showToast?.(`Loaded "${file.name}"`, 'success');
        } catch {
          window.showToast?.('Failed to read file', 'error');
        }
      } else {
        window.showToast?.('Please drop a .txt file', 'error');
      }
    });
  }
</script>
